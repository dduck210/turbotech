APP_NAME=Turbotech
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/codemoi1

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=codemoi2
DB_USERNAME=root
DB_PASSWORD=
# Matches the collation the existing tables were actually created with —
# Laravel's own default (utf8mb4_unicode_ci) would make any NEW table on a
# fresh install sort/compare Vietnamese text slightly differently than the
# rest of this schema.
DB_COLLATION=utf8mb4_general_ci

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# VietQR bank-transfer QR (app/Services/VietQrService.php). BANK_CODE is
# VietQR's short bank code (see https://api.vietqr.io/v2/banks) — "bidv" for BIDV.
BANK_CODE=
BANK_ACCOUNT_NO=
BANK_ACCOUNT_NAME=

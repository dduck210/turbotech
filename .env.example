# Leave DB_* unset for local XAMPP — defaults to the local root/no-password
# codemoi2 database unchanged. Set these when connecting to a remote/hosted
# MySQL instance instead.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=codemoi2
DB_USER=root
DB_PASS=
DB_CHARSET=utf8

SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PORT=465
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Turbotech

# VietQR bank-transfer QR (view/qr.php). BANK_CODE is VietQR's short bank
# code (see https://api.vietqr.io/v2/banks), e.g. "bidv", "vietcombank".
BANK_CODE=
BANK_ACCOUNT_NO=
BANK_ACCOUNT_NAME=

# Reopens access to public/ that the project-root .htaccess denies, so
# this is the only part of the codebase reachable over HTTP.
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>

Options -Indexes

# Static assets (images/css/js/fonts) must always be revalidated with the
# server instead of served straight from the browser's disk cache — without
# this, a plain F5 after deploying a changed asset can keep showing the old
# file until a hard refresh (Ctrl+F5) forces a bypass. no-cache still lets
# the browser send a conditional request (If-Modified-Since/If-None-Match)
# so unchanged files get a cheap 304 instead of a full re-download.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpe?g|gif|svg|webp|ico|woff2?|ttf)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
    ExpiresActive Off
</IfModule>

# Laravel front controller — send everything that isn't a real file or
# directory (assets, storage/ symlink targets, ...) to index.php.
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
